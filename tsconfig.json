{
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": [
    "packages/react-render-tracker/src/**/*.test.ts",
    "packages/react-render-tracker/src/**/*.test.tsx",
    "packages/react-render-tracker/src/test-setup.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@aether/react-render-tracker": ["./packages/react-render-tracker/src/index.ts"],
      "@aether/react-render-tracker/auto": ["./packages/react-render-tracker/src/auto.ts"]
    }
  }
}
