{
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": [
    "packages/react-render-tracker/src/**/*.test.ts",
    "packages/react-render-tracker/src/**/*.test.tsx",
    "packages/react-render-tracker/src/test-setup.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/components/AetherLogo": ["./src/shared/components/AetherLogo.tsx"],
      "@/components/ImagePreview": ["./src/shared/components/ImagePreview.tsx"],
      "@/components/Markdown": ["./src/shared/components/Markdown.tsx"],
      "@/components/MarkdownImpl": ["./src/shared/components/MarkdownImpl.tsx"],
      "@/components/ResponsiveContext": ["./src/shared/providers/ResponsiveContext.tsx"],
      "@/components/ai-elements/*": ["./src/shared/components/ai-elements/*"],
      "@/components/chat/share/*": ["./src/features/share/components/*"],
      "@/components/chat/*": ["./src/features/chat/components/*"],
      "@/components/ChatRoom": ["./src/features/chat/components/ChatRoom.tsx"],
      "@/components/sidebar/NotesButton": ["./src/features/notes/components/NotesButton.tsx"],
      "@/components/sidebar/Sidebar": ["./src/features/sidebar/components/Sidebar.tsx"],
      "@/components/sidebar/conversation/*": ["./src/features/sidebar/components/*"],
      "@/components/sidebar/search/*": ["./src/features/sidebar/components/search/*"],
      "@/components/sidebar/settings/*": ["./src/features/settings/components/*"],
      "@/components/ui/*": ["./src/shared/ui/*"],
      "@/components/notes/*": ["./src/features/notes/components/*"],
      "@/hooks/useTheme": ["./src/shared/hooks/useTheme.ts"],
      "@/hooks/useToast": ["./src/shared/hooks/useToast.ts"],
      "@/hooks/useViewportHeight": ["./src/shared/hooks/useViewportHeight.ts"],
      "@/hooks/useConversationLoader": ["./src/features/sidebar/hooks/useConversationLoader.ts"],
      "@/lib/auth/*": ["./src/features/auth/client/*"],
      "@/lib/chat/*": ["./src/features/chat/lib/*"],
      "@/lib/conversation/*": ["./src/features/sidebar/lib/*"],
      "@/lib/*": ["./src/shared/lib/*"],
      "@/server/agents/*": ["./src/features/chat/server/agents/*"],
      "@/server/base64": ["./src/shared/server/base64.ts"],
      "@/server/db/conversation-shares-db": ["./src/features/share/server/conversation-shares-db.ts"],
      "@/server/db/conversations-db": ["./src/features/sidebar/server/conversations-db.ts"],
      "@/server/db/notes-db": ["./src/features/notes/server/notes-db.ts"],
      "@/server/db/prompt-quota-db": ["./src/features/quota/server/prompt-quota-db.ts"],
      "@/server/env": ["./src/shared/server/env.ts"],
      "@/server/functions/admin/redeem-codes": ["./src/features/quota/server/redeem-codes.ts"],
      "@/server/functions/auth/*": ["./src/features/auth/server/*"],
      "@/server/functions/chat/*": ["./src/features/chat/server/functions/*"],
      "@/server/functions/conversations": ["./src/features/sidebar/server/conversations.ts"],
      "@/server/functions/notes": ["./src/features/notes/server/notes.ts"],
      "@/server/functions/quota": ["./src/features/quota/server/quota.ts"],
      "@/server/functions/shares": ["./src/features/share/server/shares.ts"],
      "@/server/functions/theme": ["./src/shared/server/theme.ts"],
      "@/server/functions/tts": ["./src/features/chat/server/functions/tts.ts"],
      "@/stores/zustand/useChatRequestStore": ["./src/features/chat/store/useChatRequestStore.ts"],
      "@/stores/zustand/useComposerStore": ["./src/features/chat/store/useComposerStore.ts"],
      "@/stores/zustand/useChatSessionStore": ["./src/features/sidebar/store/useChatSessionStore.ts"],
      "@/stores/zustand/useEditingStore": ["./src/features/chat/store/useEditingStore.ts"],
      "@/stores/zustand/useNotesStore": ["./src/features/notes/store/useNotesStore.ts"],
      "@/stores/zustand/toast": ["./src/shared/stores/toast.ts"],
      "@/types/chat-api": ["./src/features/chat/types/chat-api.ts"],
      "@/types/chat-event-types": ["./src/features/chat/types/chat-event-types.ts"],
      "@/types/conversation": ["./src/features/sidebar/types/conversation.ts"],
      "@/types/message": ["./src/features/chat/types/message.ts"],
      "@/types/share": ["./src/features/share/types/share.ts"],
      "@/*": ["./src/*"],
      "@aether/react-render-tracker": ["./packages/react-render-tracker/src/index.ts"],
      "@aether/react-render-tracker/auto": ["./packages/react-render-tracker/src/auto.ts"]
    }
  }
}
