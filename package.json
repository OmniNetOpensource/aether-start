{
  "name": "aether-start",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host :: --port 3000 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "auth:generate": "better-auth generate --config src/features/auth/server/auth.ts --output src/features/auth/server/auth.schema.ts --yes",
    "auth:migration:generate": "drizzle-kit generate --dialect sqlite --driver d1-http --schema src/features/auth/server/auth.schema.ts --out migrations --name better_auth",
    "cf:typegen": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false wrangler types",
    "cf:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "cf:deploy": "vite build && node scripts/patch-wrangler-config.mjs && wrangler deploy",
    "cf:sync-secrets": "node scripts/sync-env-to-cloudflare.mjs",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && pnpm lint && pnpm build",
    "test": "pnpm test:app",
    "test:app": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@floating-ui/react": "^0.27.18",
    "@google/genai": "^1.43.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/cloudflare": "^10.40.0",
    "@sentry/react": "^10.40.0",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@supadata/js": "^1.4.0",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.164.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@tanstack/router-plugin": "^1.164.0",
    "better-auth": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.3",
    "github-markdown-css": "^5.9.0",
    "html-to-image": "^1.11.13",
    "katex": "^0.16.33",
    "lucide-react": "^0.575.0",
    "lxgw-wenkai-webfont": "^1.7.0",
    "motion": "^12.34.3",
    "nes.css": "^2.3.0",
    "openai": "^6.25.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.20",
